---
// src/pages/portfolio/index.astro
import Layout from '../../layouts/Layout.astro';

let projects = [];

try {
    const STRAPI_URL = import.meta.env.STRAPI_URL || 'http://localhost:1337';
    const response = await fetch(`${STRAPI_URL}/api/portfolios?populate=*`);
    
    if (response.ok) {
        const { data } = await response.json();
        projects = data || [];
    }
} catch (error) {
    console.warn("Strapi portfolio fetch skipped/failed (using empty list):", error);
}
---

<Layout title="Portfolio | Marcel.ops">
    
    <header class="mb-12 border-b border-slate-800 pb-8">
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
            My <span class="text-sky-400">Portfolio</span>
        </h1>
        <p class="text-lg text-slate-400 max-w-2xl">
            A collection of my recent work in cloud infrastructure, GitOps, and automation.
        </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        {projects.map((project: any) => (
            <a 
                href={`/portfolio/${project.slug}`} 
                class="block p-6 rounded-xl bg-slate-900 border border-slate-800 hover:border-sky-500/50 hover:bg-slate-800/80 transition-all shadow-lg flex flex-col h-full"
            >
                <h2 class="text-xl font-bold text-slate-200 mb-2">
                    {project.title}
                </h2>
                
                {project.description && (
                    <p class="text-sm text-slate-400 line-clamp-3 mb-6 flex-grow">
                        {project.description}
                    </p>
                )}
                
                <div class="mt-auto text-sky-400 text-sm font-medium flex items-center gap-2">
                    View Infrastructure 
                    <span aria-hidden="true">&rarr;</span>
                </div>
            </a>
        ))}
        
    </div>
    
    {projects.length === 0 && (
        <div class="text-center py-12 text-slate-500 bg-slate-900/50 rounded-xl border border-dashed border-slate-700/50">
            No projects have been added to the portfolio yet or CMS is currently offline.
        </div>
    )}

</Layout>