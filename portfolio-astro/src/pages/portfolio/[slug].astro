---
// src/pages/portfolio/[slug].astro
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked'; 

export async function getStaticPaths() {
    // Fetching from the portfolios collection endpoint with block population
    const response = await fetch('http://localhost:1337/api/portfolios?populate=blocks');
    const { data } = await response.json();

    const projects = data || [];

    return projects.map((item: any) => ({
        params: { slug: item.slug }, 
        props: { project: item },      
    }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | Marcel.ops`}>
    
    <article class="max-w-4xl mx-auto py-12 px-4">
        <header class="mb-10 pb-6 border-b border-slate-800">
            <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight leading-tight">
                {project.title}
            </h1>
            
            <div class="flex flex-wrap items-center gap-4 text-sm font-mono text-slate-400 mt-4">
                <span class="bg-sky-500/10 border border-sky-500/30 px-3 py-1 rounded-md text-sky-400 font-medium">
                    Infrastructure Case Study
                </span>
                <span>Published: {new Date(project.publishedAt).toLocaleDateString()}</span>
            </div>
        </header>

        <!-- Tailwind Typography Processor -->
        <div class="prose prose-invert prose-sky max-w-none text-slate-300">
            
            {project.blocks && project.blocks.length > 0 ? (
                project.blocks.map((block: any) => {
                    
                    // Check if the current block is our Body component
                    if (block.__component && block.__component.toLowerCase().includes('body')) {
                        
                        // Extract the markdown string from our new 'content' field
                        const rawMarkdown = block.content || '';
                        
                        // Parse it into HTML
                        const parsedHTML = marked.parse(rawMarkdown);
                        
                        // Render it to the screen
                        return <div set:html={parsedHTML} class="mb-6" />
                    }
                    
                    return null;
                })
            ) : (
                <p class="text-slate-500 italic">This case study does not contain any content blocks yet.</p>
            )}

        </div>
    </article>

</Layout>