---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Marcel Avila | Cloud Infrastructure & AI Automation">
    <div class="pt-12 pb-24">
        <!-- Hero Section -->
        <section class="flex flex-col md:flex-row items-center justify-between gap-12">
            <div class="flex-1 space-y-6">
                <h1 class="text-5xl md:text-6xl font-extrabold text-white leading-tight tracking-tight">
                    Building the future of <br />
                    <span class="text-sky-400">Cloud Infrastructure</span> &amp; <br />
                    AI Automation.
                </h1>
                <p class="text-lg text-slate-400 max-w-2xl leading-relaxed">
                    Hi, I'm Marcel. I design and build highly available, secure, and automated environments using Kubernetes, GitOps pipelines, and AI integrations. Welcome to my cloud-native portfolio.
                </p>
            </div>
            
            <!-- Rocket Animation Container -->
            <div class="flex-shrink-0 relative w-72 h-72 rounded-full border-[3px] border-sky-500/30 bg-gradient-to-tr from-sky-500/10 to-transparent flex items-center justify-center">
                <script type="module" src="https://unpkg.com/@dotlottie/player-component@latest/dist/dotlottie-player.mjs"></script>
                <dotlottie-player 
                    src="/Rocket_Launch.lottie" 
                    background="transparent" 
                    speed="1" 
                    style="width: 200px; height: 200px;" 
                    loop="true" 
                    autoplay="true">
                </dotlottie-player>
            </div>
        </section>
    </div>
</Layout>