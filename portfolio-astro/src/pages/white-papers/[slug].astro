---
// src/pages/white-papers/[slug].astro
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked'; 

export async function getStaticPaths() {
    const response = await fetch('http://localhost:1337/api/white-papers?populate=blocks');
    const { data } = await response.json();
    const papers = data || [];

    return papers.map((item: any) => ({
        params: { slug: item.slug }, 
        props: { paper: item },      
    }));
}

const { paper } = Astro.props;
---

<Layout title={`${paper.title} | Marcel.ops`}>
    
    <article class="max-w-4xl mx-auto py-12 px-4">
        <header class="mb-10 pb-6 border-b border-slate-800">
            <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight leading-tight">
                {paper.title}
            </h1>
            <p class="text-sky-400 font-mono text-sm">
                Published: {new Date(paper.publishedAt).toLocaleDateString()}
            </p>
        </header>

        <div class="prose prose-invert prose-sky max-w-none text-slate-300">
            
            {paper.blocks && paper.blocks.length > 0 ? (
                paper.blocks.map((block: any) => {
                    
                    // Check if the current block is our Body component
                    if (block.__component && block.__component.toLowerCase().includes('body')) {
                        // Extract the markdown string from our new 'content' field
                        const rawMarkdown = block.content || '';
                        
                        // Parse it into HTML
                        const parsedHTML = marked.parse(rawMarkdown);
                        
                        // Render it to the screen
                        return <div set:html={parsedHTML} class="mb-6" />
                    }
                    
                    return null;
                })
            ) : (
                <p class="text-slate-500 italic">This white paper does not contain any content blocks yet.</p>
            )}

        </div>
    </article>

</Layout>