---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Marcel Avila">
    <div class="pt-12 pb-24">
        <!-- Contact Form Section -->
        <section class="max-w-2xl mx-auto text-center">
            <h2 class="text-3xl font-bold text-white mb-4">Get in Touch</h2>
            <p class="text-slate-400 mb-10">Have an idea or project you want to collaborate on? Drop a message below.</p>
            
            <form class="space-y-6 text-left">
                <div>
                    <label class="block text-xs font-bold tracking-widest text-slate-400 uppercase mb-2">Name</label>
                    <input type="text" class="w-full bg-slate-800/80 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-sky-400 transition-colors" />
                </div>
                <div>
                    <label class="block text-xs font-bold tracking-widest text-slate-400 uppercase mb-2">Email Address</label>
                    <input type="email" class="w-full bg-slate-800/80 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-sky-400 transition-colors" />
                </div>
                <div>
                    <label class="block text-xs font-bold tracking-widest text-slate-400 uppercase mb-2">Message</label>
                    <textarea rows="5" class="w-full bg-slate-800/80 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-sky-400 transition-colors resize-none"></textarea>
                </div>
                <button type="submit" class="w-full bg-sky-400 hover:bg-sky-300 text-slate-950 font-bold py-4 rounded-lg transition-colors text-lg">
                    Send Message
                </button>
            </form>
        </section>
    </div>
</Layout>