---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 | System Not Found">
    <div class="flex flex-col items-center justify-center py-20 text-center">
        <script type="module" src="https://unpkg.com/@dotlottie/player-component@latest/dist/dotlottie-player.mjs"></script>
        
        <!-- Notice the class="invert hue-rotate-180" added below -->
        <dotlottie-player 
            src="/Rocket_in_space.lottie" 
            background="transparent" 
            speed="1" 
            class="invert hue-rotate-180"
            style="width: 250px; height: 250px;" 
            loop 
            autoplay>
        </dotlottie-player>

        <h1 class="text-6xl font-extrabold text-white mt-8 mb-4">404</h1>
        <p class="text-xl text-slate-400 mb-8 max-w-lg">
            Node disconnected. The route you are looking for has drifted into deep space or no longer exists in the cluster.
        </p>
        <a href="/" class="bg-sky-400 hover:bg-sky-300 text-slate-950 font-bold py-3 px-8 rounded-lg transition-colors inline-block">
            Return to Base
        </a>
    </div>
</Layout>