---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="About | Marcel">
    <div class="max-w-4xl mx-auto py-16">
        
        <!-- Header Section with the New Animation -->
        <div class="flex items-center space-x-6 mb-12 border-b border-slate-800/60 pb-8">
            <div class="w-24 h-24 flex-shrink-0">
                <script type="module" src="https://unpkg.com/@dotlottie/player-component@latest/dist/dotlottie-player.mjs"></script>
                <dotlottie-player 
                    src="/Rocket_in_space.lottie" 
                    background="transparent" 
                    speed="1" 
                    style="width: 100%; height: 100%;" 
                    loop 
                    autoplay>
                </dotlottie-player>
            </div>
            <div>
                <h1 class="text-4xl font-bold text-white mb-2">About the Engineer</h1>
                <p class="text-lg text-slate-400">Building resilient, cloud-native infrastructure.</p>
            </div>
        </div>

        <!-- Content Area -->
        <div class="prose prose-invert prose-slate max-w-none">
            <p class="text-slate-300 leading-relaxed text-lg">
                Your professional bio and background will go here...
            </p>
        </div>

    </div>
</Layout>