                        LinkedIn
                    </a>
                    
                    <a 
                        href="https://github.com/Marcelus85er" 
                        target="_blank" 
                        class="flex items-center gap-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-white px-4 py-2 rounded-lg transition-all text-sm font-medium"
