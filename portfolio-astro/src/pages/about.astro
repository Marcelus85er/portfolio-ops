---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';

let aboutData = null;

try {
    const STRAPI_URL = import.meta.env.STRAPI_URL || 'http://localhost:1337';
    const response = await fetch(`${STRAPI_URL}/api/about?populate=*`);
    
    if (response.ok) {
        const json = await response.json();
        // Support both Strapi v5 (json.data) and Strapi v4 (json.data.attributes)
        aboutData = json?.data?.attributes || json?.data || null;
    }
} catch (error) {
    console.warn("Strapi about page fetch skipped/failed:", error);
}

// Header Titles
const title = aboutData?.title || "About the Engineer";
const tagline = "Building resilient, cloud-native infrastructure and AI-driven automation.";

// Helper function to extract and format Bio text (handles string & Strapi v5 Blocks)
function parseBio(bioField: any): string {
    if (!bioField) {
        return "Your professional bio and background will go here. You can expand on your experience with Kubernetes, MinIO, Postgres, and GitOps workflows.\n\nThis is housed inside a custom dark slate card to match the rest of the site's aesthetic seamlessly.";
    }
    
    // 1. Plain String
    if (typeof bioField === 'string') {
        return bioField;
    }
    
    // 2. Strapi v5 Rich-Text Blocks (Array of Node objects)
    if (Array.isArray(bioField)) {
        return bioField
            .map((block) => {
                if (block.children) {
                    return block.children.map((child: any) => child.text || '').join('');
                }
                return '';
            })
            .filter(Boolean)
            .join('\n\n');
    }
    
    return String(bioField);
}

const bioText = parseBio(aboutData?.bio);

// Helper function to resolve media URLs across local dev & storage APIs
function getImageUrl(mediaField: any): string {
    const FALLBACK_IMAGE = "/marcel-profile.webp"; // Local static asset fallback
    if (!mediaField) return FALLBACK_IMAGE;
    
    const rawObj = Array.isArray(mediaField) ? mediaField[0] : mediaField;
    const mediaObj = rawObj?.data?.attributes || rawObj?.attributes || rawObj;
    const url = mediaObj?.url;

    if (!url) return FALLBACK_IMAGE;

    if (url.startsWith('http://') || url.startsWith('https://')) {
        return url;
    }

    const baseUrl = import.meta.env.STRAPI_URL || 'http://localhost:1337';
    return `${baseUrl}${url}`;
}

const profileImageUrl = getImageUrl(aboutData?.profileImage);
---

<Layout title="About | Marcel Avila">
    <div class="pt-12 pb-24 max-w-4xl mx-auto">
        
        <!-- Header Section: Avatar + Title + Social Links -->
        <div class="flex flex-col md:flex-row items-center md:items-start gap-8 mb-12 border-b border-slate-800/60 pb-12">
            
            <!-- Circular Avatar with Blue Glow -->
            <div class="w-40 h-40 flex-shrink-0 rounded-full border-[3px] border-sky-500/30 overflow-hidden bg-slate-800 shadow-xl shadow-sky-900/20">
                <img 
                    src={profileImageUrl} 
                    alt="Marcel Avila" 
                    loading="lazy" 
                    decoding="async" 
                    class="w-full h-full object-cover"
                />
            </div>
            
            <!-- Title, Subtitle & Social Links -->
            <div class="text-center md:text-left flex-1">
                <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">{title}</h1>
                <p class="text-lg text-slate-400 mb-6">{tagline}</p>
                
                <div class="flex items-center justify-center md:justify-start gap-4">
                    <a 
                        href="https://www.linkedin.com/in/marcel-avila-esquivel-aa520553/" 
                        target="_blank" 
                        class="flex items-center gap-2 bg-slate-800 hover:bg-sky-500/10 border border-slate-700 hover:border-sky-500/50 text-slate-300 hover:text-sky-400 px-4 py-2 rounded-lg transition-all text-sm font-medium"
