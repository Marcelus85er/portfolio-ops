---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Insights & White Papers | Marcel">
    <div class="pt-12 pb-24">
        <h1 class="text-4xl font-bold text-white mb-2">Latest Insights</h1>
        <p class="text-slate-400 mb-12">Thoughts on DevOps, systems engineering, and automated workflows.</p>

        <ul class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {posts.map((post) => (
                <li class="bg-slate-800/80 rounded-2xl border border-slate-700/50 overflow-hidden hover:border-sky-500/50 transition-colors">
                    <a href={`/blog/${post.slug}/`} class="block p-8">
                        <h4 class="text-2xl font-bold text-white mb-3">{post.data.title}</h4>
                        <p class="text-slate-400 line-clamp-3">{post.data.description}</p>
                    </a>
                </li>
            ))}
        </ul>
    </div>
</Layout>