---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cloud API | Marcel Avila">
    <div class="pt-12 pb-24">
        <!-- Cloud Storage & API Section -->
        <section>
            <h2 class="text-3xl font-bold text-white mb-2">Cloud Storage & API</h2>
            <p class="text-slate-400 mb-10">Test the live connection to the Kubernetes backend, Postgres, and MinIO storage.</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Backend Status Card -->
                <div class="bg-slate-800/80 rounded-2xl p-8 border border-slate-700/50">
                    <h3 class="text-xl font-bold text-white mb-6">Backend Status</h3>
                    <button class="border border-slate-600 hover:border-slate-400 text-slate-300 px-6 py-2.5 rounded-lg transition-colors text-sm font-medium">
                        Ping API
                    </button>
                </div>

                <!-- Upload Media Card -->
                <div class="bg-slate-800/80 rounded-2xl p-8 border border-slate-700/50">
                    <h3 class="text-xl font-bold text-white mb-2">Upload Media to MinIO</h3>
                    <p class="text-slate-500 text-sm mb-6">Accepts Images, PDFs, TXT, DOCX, MP3, and MP4 (Max 50MB).</p>
                    <div class="flex items-center gap-4 mb-6">
                        <button class="bg-slate-900 text-slate-300 px-4 py-2 rounded-lg text-sm font-medium hover:text-white transition-colors">Choose File</button>
                        <span class="text-slate-500 text-sm">No file chosen</span>
                    </div>
                    <button class="w-full bg-sky-400 hover:bg-sky-300 text-slate-950 font-bold py-3 rounded-lg transition-colors">
                        Upload File
                    </button>
                </div>
            </div>
        </section>
    </div>
</Layout>