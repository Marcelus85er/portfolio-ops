---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cloud API | Marcel Avila">
    <div class="pt-12 pb-24">
        <!-- Cloud Storage & API Section -->
        <section>
            <h2 class="text-3xl font-bold text-white mb-2">Cloud Storage & API</h2>
            <p class="text-slate-400 mb-10">Test the live connection to the Kubernetes backend, Postgres, and MinIO storage.</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Backend Status Card -->
                <div class="bg-slate-800/80 rounded-2xl p-8 border border-slate-700/50 flex flex-col">
                    <h3 class="text-xl font-bold text-white mb-6">Backend Status</h3>
                    <button id="ping-btn" class="w-max border border-slate-600 hover:border-slate-400 text-slate-300 px-6 py-2.5 rounded-lg transition-colors text-sm font-medium mb-6">
                        Ping API
                    </button>
                    <!-- Terminal Output Window -->
                    <div class="bg-slate-950 border border-slate-800 rounded-lg p-4 h-32 overflow-y-auto">
                        <pre id="ping-output" class="text-emerald-400 font-mono text-xs whitespace-pre-wrap">Awaiting connection...</pre>
                    </div>
                </div>

                <!-- Upload Media Card -->
                <div class="bg-slate-800/80 rounded-2xl p-8 border border-slate-700/50 flex flex-col">
                    <h3 class="text-xl font-bold text-white mb-2">Upload Media to MinIO</h3>
                    <p class="text-slate-500 text-sm mb-6">Accepts Images, PDFs, TXT, DOCX, MP3, and MP4 (Max 50MB).</p>
                    
                    <div class="flex items-center gap-4 mb-6">
                        <!-- Hidden File Input -->
                        <input type="file" id="file-input" class="hidden" />
                        <button id="choose-file-btn" class="bg-slate-900 border border-slate-700 text-slate-300 px-4 py-2 rounded-lg text-sm font-medium hover:text-white hover:border-slate-500 transition-colors">
                            Choose File
                        </button>
                        <span id="file-name" class="text-slate-500 text-sm truncate max-w-[200px]">No file chosen</span>
                    </div>
                    
                    <button id="upload-btn" class="w-full bg-sky-400 hover:bg-sky-300 text-slate-950 font-bold py-3 rounded-lg transition-colors mb-6 disabled:opacity-50 disabled:cursor-not-allowed">
                        Upload File
                    </button>
                    
                    <!-- Terminal Output Window -->
                    <div class="bg-slate-950 border border-slate-800 rounded-lg p-4 h-32 overflow-y-auto">
                        <pre id="upload-output" class="text-emerald-400 font-mono text-xs whitespace-pre-wrap">Awaiting upload...</pre>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>

<script>
    // Point this to your live domain
    const API_BASE = 'https://marcel-avila.com/api';

    // ==========================================
    // 1. Ping API Logic
    // ==========================================
    const pingBtn = document.getElementById('ping-btn');
    const pingOutput = document.getElementById('ping-output');

    pingBtn.addEventListener('click', async () => {
        pingOutput.textContent = 'Pinging server...';
        pingOutput.classList.replace('text-rose-400', 'text-emerald-400');
        
        try {
            const response = await fetch(`${API_BASE}/health`);
            const data = await response.json();
            // Format the JSON with 2 spaces for a pretty terminal look
            pingOutput.textContent = JSON.stringify(data, null, 2); 
        } catch (error) {
            pingOutput.textContent = `Error: Cannot reach the backend.\n${error.message}`;
            pingOutput.classList.replace('text-emerald-400', 'text-rose-400');
        }
    });

    // ==========================================
    // 2. File Selection & Upload Logic
    // ==========================================
    const fileInput = document.getElementById('file-input');
    const chooseFileBtn = document.getElementById('choose-file-btn');
    const fileNameDisplay = document.getElementById('file-name');
    const uploadBtn = document.getElementById('upload-btn');
    const uploadOutput = document.getElementById('upload-output');

    // Make the custom button trigger the hidden input
    chooseFileBtn.addEventListener('click', () => fileInput.click());

    // Update the text when a user picks a file
    fileInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
            fileNameDisplay.textContent = file.name;
            fileNameDisplay.classList.replace('text-slate-500', 'text-slate-300');
        } else {
            fileNameDisplay.textContent = 'No file chosen';
            fileNameDisplay.classList.replace('text-slate-300', 'text-slate-500');
        }
    });

    // Handle the actual upload
    uploadBtn.addEventListener('click', async () => {
        const file = fileInput.files[0];
        if (!file) {
            uploadOutput.textContent = 'Error: Please select a file first.';
            uploadOutput.classList.replace('text-emerald-400', 'text-rose-400');
            return;
        }

        uploadOutput.textContent = 'Uploading to MinIO...';
        uploadOutput.classList.replace('text-rose-400', 'text-emerald-400');
        uploadBtn.disabled = true; // Prevent double-clicking

        // Bundle the file into FormData
        const formData = new FormData();
        formData.append('image', file); // 'image' matches your backend multer setup

        try {
            const response = await fetch(`${API_BASE}/upload`, {
                method: 'POST',
                body: formData
            });
            
            const data = await response.json();
            
            if (!response.ok) {
                throw new Error(data.error || 'Upload failed');
            }

            uploadOutput.textContent = JSON.stringify(data, null, 2);
            
            // Clear the file input after success
            fileInput.value = ''; 
            fileNameDisplay.textContent = 'No file chosen';
            fileNameDisplay.classList.replace('text-slate-300', 'text-slate-500');

        } catch (error) {
            uploadOutput.textContent = `Upload Error:\n${error.message}`;
            uploadOutput.classList.replace('text-emerald-400', 'text-rose-400');
        } finally {
            uploadBtn.disabled = false; // Re-enable the button
        }
    });
</script>