---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio | Marcel Avila">
    <div class="pt-12 pb-24">
        <!-- Featured Projects Section -->
        <section>
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
                <div>
                    <h2 class="text-3xl font-bold text-white mb-2">Featured Projects</h2>
                    <p class="text-slate-400">A showcase of my cloud, automation, and AI infrastructure architectures.</p>
                </div>
                <!-- Filter Pills -->
                <div class="flex space-x-3 text-sm font-medium">
                    <button class="bg-sky-400 text-slate-950 px-4 py-2 rounded-full">All</button>
                    <button class="bg-slate-800 text-slate-300 hover:text-white px-4 py-2 rounded-full transition-colors">Cloud/K8s</button>
                    <button class="bg-slate-800 text-slate-300 hover:text-white px-4 py-2 rounded-full transition-colors">AI/Automation</button>
                </div>
            </div>

            <!-- Project Cards Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Card 1 -->
                <div class="bg-slate-800/80 rounded-2xl p-8 hover:bg-slate-800 transition-colors border border-slate-700/50">
                    <span class="text-xs font-bold text-sky-400 tracking-widest uppercase mb-3 block">Cloud/K8s</span>
                    <h3 class="text-2xl font-bold text-white mb-3">GitOps K3d Cluster</h3>
                    <p class="text-slate-400 mb-6 line-clamp-3">A locally hosted Kubernetes cluster driven entirely by declarative configurations and managed by ArgoCD.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="bg-slate-900 text-slate-300 text-xs px-3 py-1.5 rounded-md font-medium">K3d</span>
                        <span class="bg-slate-900 text-slate-300 text-xs px-3 py-1.5 rounded-md font-medium">ArgoCD</span>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="bg-slate-800/80 rounded-2xl p-8 hover:bg-slate-800 transition-colors border border-slate-700/50">
                    <span class="text-xs font-bold text-purple-400 tracking-widest uppercase mb-3 block">AI/Automation</span>
                    <h3 class="text-2xl font-bold text-white mb-3">n8n AI Agent Brain</h3>
                    <p class="text-slate-400 mb-6 line-clamp-3">An automation hub hosted on a VPS orchestrating LLMs to automate research, messaging, and data updates.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="bg-slate-900 text-slate-300 text-xs px-3 py-1.5 rounded-md font-medium">n8n</span>
                        <span class="bg-slate-900 text-slate-300 text-xs px-3 py-1.5 rounded-md font-medium">OpenAI</span>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>