---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. Fetch all posts
const allPosts = await getCollection('blog');

// 2. The Mechanism: Filter only posts that have "portfolio" in their tags
const portfolioProjects = allPosts.filter(post => 
    post.data.tags && post.data.tags.includes('portfolio')
);
---

<Layout title="Portfolio | Marcel Avila">
    <div class="pt-12 pb-24">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-4">
            <div>
                <h2 class="text-3xl font-bold text-white mb-2">Featured Projects</h2>
                <p class="text-slate-400">Dynamically generated from the Markdown database.</p>
            </div>
        </div>

        <!-- Native CSS Snap-Scroll Carousel -->
        <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-8 hide-scrollbar">
            
            {portfolioProjects.length > 0 ? (
                portfolioProjects.map((project) => (
                    <!-- Carousel Card -->
                    <div class="snap-center shrink-0 w-[85vw] md:w-[400px] bg-slate-800/80 rounded-2xl p-8 border border-slate-700/50 hover:border-sky-500/50 transition-colors">
                        <h3 class="text-2xl font-bold text-white mb-3">{project.data.title}</h3>
                        <p class="text-slate-400 mb-6 line-clamp-3">{project.data.description}</p>
                        <a href={`/blog/${project.slug}/`} class="text-sky-400 font-bold hover:text-sky-300">Read Architecture &rarr;</a>
                    </div>
                ))
            ) : (
                <div class="p-8 border border-dashed border-slate-700 rounded-2xl w-full text-center text-slate-500">
                    No portfolio projects found. Add tags: ["portfolio"] to a markdown file!
                </div>
            )}

        </div>
    </div>
</Layout>