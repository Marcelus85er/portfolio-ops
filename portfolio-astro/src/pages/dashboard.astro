---
import { auth } from "../lib/auth";

// Check the incoming request cookies to parse the Better Auth session
const session = await auth.api.getSession({
  headers: Astro.request.headers,
});

// Boot unauthorized traffic back to safety
if (!session) {
  return Astro.redirect("/");
}

const user = session.user;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Secure Base Dashboard</title>
  </head>
  <body class="bg-slate-950 text-slate-200 min-h-screen flex flex-col font-sans p-8">
    <div class="max-w-md mx-auto mt-20 bg-slate-900 rounded-xl p-6 shadow-xl border border-slate-800">
      <h1 class="text-2xl font-bold mb-4 text-emerald-400">🎉 Handshake Success!</h1>
      <p class="text-slate-400 text-sm mb-6">Your session has been securely validated through Keycloak and registered into Postgres.</p>
      
      <div class="border-t border-slate-800 pt-4">
        <h2 class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-3">User Profile Identity</h2>
        <ul class="space-y-2 text-sm">
          <li><strong class="text-slate-400 font-medium">Full Name:</strong> {user.name}</li>
          <li><strong class="text-slate-400 font-medium">Email Address:</strong> {user.email}</li>
          <li><strong class="text-slate-400 font-medium">Internal ID:</strong> <span class="font-mono text-xs bg-slate-950 px-1.5 py-0.5 rounded border border-slate-800">{user.id}</span></li>
        </ul>
      </div>

      <button id="logout-btn" class="mt-6 w-full bg-rose-400 hover:bg-rose-500 text-slate-950 font-bold py-2.5 px-4 rounded-lg transition-colors cursor-pointer">
        Terminate Session (Log Out)
      </button>
    </div>

    <script>
      import { authClient } from "../lib/auth-client";

      document.getElementById("logout-btn")?.addEventListener("click", async () => {
        await authClient.signOut();
        window.location.href = "/";
      });
    </script>
  </body>
</html>