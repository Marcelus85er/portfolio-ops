---
import '../styles/global.css';

const { title = "Marcel | Cloud Engineer" } = Astro.props;

// Fallback navigation in case Strapi is unreachable during build
let menuItems = [
    { label: 'About', URL: '/about' },
    { label: 'Portfolio', URL: '/portfolio' },
    { label: 'White Papers', URL: '/white-papers' }
];

try {
    const STRAPI_URL = import.meta.env.STRAPI_URL || 'http://localhost:1337';
    const response = await fetch(`${STRAPI_URL}/api/main-navigation?populate=*`);
    
    if (response.ok) {
        const { data } = await response.json();
        if (data?.Menu) {
            menuItems = data.Menu;
        }
    }
} catch (error) {
    console.warn("Strapi navigation fetch skipped/failed (using default menu):", error);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
</head>
<body class="bg-slate-950 text-slate-200 min-h-screen flex flex-col font-sans">
    
    <!-- Global Navigation -->
    <nav class="border-b border-slate-800 bg-slate-950 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
            <div class="font-bold text-2xl text-white">
                <a href="/">Marcel<span class="text-blue-500">.ops</span></a>
            </div>
            
            <!-- Dynamic Link Generation -->
            <div class="flex space-x-8 text-sm font-medium">
                {menuItems.map((item: any) => (
                    <a href={item.URL} class="text-slate-300 hover:text-white transition-colors">
                        {item.label}
                    </a>
                ))}
            </div>
            
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow w-full max-w-7xl mx-auto px-4 py-12">
        <slot />
    </main>

    <!-- Global Footer -->
    <footer class="border-t border-slate-800 py-8 mt-auto">
        <div class="max-w-7xl mx-auto px-4 text-center text-slate-500 text-sm">
            <p>&copy; 2026 Marcel. Cloud Infrastructure & DevOps Portfolio.</p>
        </div>
    </footer>

</body>
</html>